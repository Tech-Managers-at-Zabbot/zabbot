datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- USER MODEL ---
model User {
  id                String                   @id @default(uuid())
  clerkId           String                   @unique
  name              String?
  email             String?                  @unique
  avatarUrl         String?
  image             String?
  role              UserRole                 @default(USER)
  status            String                   @default("ACTIVE")
  xp                Int                      @default(0)
  hearts            Int                      @default(5)
  currentStreak     Int                      @default(0)
  longestStreak     Int                      @default(0)
  streakFreezes     Int                      @default(0)
  isStreakFrozen    Boolean                  @default(false)
  streakLastUpdated DateTime                 @default(now())
  bestParaScore     Int                      @default(0)
  paraRankTitle     String?
  lastActive        DateTime?                @default(now())
  themePreference   String                   @default("system")

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  conversations     AIConversationLog[]
  activityLogs      ActivityLog[]
  attempts          Attempt[]
  initiatedLogs     AuditLog[]               @relation("Initiator")
  flashcards        Flashcard[]
  subscription      Subscription?
  achievements      UserAchievement[]
  progress          UserLessonProgress[]
  vocabulary        UserVocabularyProgress[]

  @@index([clerkId])
}

// ---AI AGENTS ---
model AIAgent {
  id          String   @id @default(uuid())
  name        String
  description String
  mascot      String
  route       String   @unique
  xpReward    Int      @default(50)
  color       String
  tag         String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- JOURNEYS & SPARKS ---
model Journey {
  id             String        @id @default(uuid())
  title          String
  description    String?       @db.Text
  imageThumbnail String?
  order          Float
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sparks         Spark[]
}

model Spark {
  id             String        @id @default(uuid())
  journeyId      String?
  order          Int           @default(1)
  title          String
  slug           String        @unique
  description    String?       @db.Text
  difficulty     String        @default("Beginner")
  xpReward       Int           @default(50)
  category       SparkCategory @default(JOURNEY)
  imageThumbnail String?
  bgColor        String?       @default("#24A5EE")
  isPublished    Boolean       @default(false)
  timeEstimate   Int?          @default(5)
  status         ContentStatus @default(DRAFT)

  // Cultural Meta
  proverbYoruba  String?
  proverbEnglish String?
  honorificRule  String?       @db.Text

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  contentBlocks  ContentBlock[]
  exercises      Exercise[]
  userProgress   UserLessonProgress[]
  vocabulary     Vocabulary[]

  journey        Journey?      @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, order])
  @@index([journeyId])
  @@map("sparks_new")
}

// --- CONTENT BLOCKS & EXERCISES ---
model ContentBlock {
  id        String      @id @default(uuid())
  type      ContentType
  order     Int         @default(0)
  yoruba    String?
  english   String?
  grammar   String?     @db.Text
  audioUrl  String?
  videoUrl  String?
  fileUrl   String?
  sparkId   String
  spark     Spark       @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([sparkId])
}

model Exercise {
  id            String       @id @default(uuid())
  type          ExerciseType @default(MULTIPLE_CHOICE)
  question      String
  options       String[]
  correctIndex  Int          @default(0)
  correctAnswer String?
  explanation   String?      @db.Text
  sparkId       String
  spark         Spark        @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([sparkId])
}

// --- USER PROGRESS ---
model UserLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  sparkId     String
  score       Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  spark       Spark     @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sparkId])
  @@index([userId])
  @@index([sparkId])
}

// --- ACTIVITY & AUDIT LOGS ---
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  xpGained  Int
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  status    String
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation("Initiator", fields: [userId], references: [id], onDelete: Cascade)
}

// --- VOCABULARY & FLASHCARDS ---
model Vocabulary {
  id                 String                   @id @default(uuid())
  yorubaWord         String
  englishTranslation String
  exampleSentence    String?
  audioUrl           String?
  sparkId            String?
  lessonId           String?
  phonemeStamps      PhonemeStamp[]
  userProgress       UserVocabularyProgress[]
  spark              Spark?                   @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([sparkId])
}

model PhonemeStamp {
  id         String     @id @default(uuid())
  vocabId    String
  syllable   String
  startTime  Float      @default(0)
  endTime    Float      @default(0)
  toneType   String
  vocabulary Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
}

model UserVocabularyProgress {
  id           String     @id @default(uuid())
  userId       String
  vocabularyId String
  masteryLevel Int        @default(0)
  lastReviewed DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
}

// --- FLASHCARDS ---
model Flashcard {
  id           String    @id @default(uuid())
  userId       String
  front        String
  back         String
  masteryLevel Int       @default(0)
  nextReview   DateTime  @default(now())
  lastReviewed DateTime?
  createdAt    DateTime  @default(now())   
  sourceLesson String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, back], name: "user_flashcard_id")
}

// --- ACHIEVEMENTS ---
model Achievement {
  id               String            @id @default(uuid())
  title            String
  description      String
  iconUrl          String
  xpValue          Int               @default(100)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- SUBSCRIPTIONS ---
model Subscription {
  id                     String          @id @default(uuid())
  userId                 String          @unique
  provider               PaymentProvider
  providerCustomerId     String?
  providerSubscriptionId String?
  plan                   String?
  status                 SubStatus       @default(TRIAL_ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialStart             DateTime?
  trialEnd               DateTime?
  cancelAtPeriodEnd      Boolean         @default(false)
  cancelledAt            DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
}

// --- AI CONVERSATION & DAILY WORDS ---
model AIConversationLog {
  id        String   @id @default(uuid())
  userId    String
  prompt    String
  response  String
  context   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TodaysWord {
  id          String   @id @default(uuid())
  word        String   @unique
  phonetic    String
  meaning     String
  displayDate DateTime @unique
  createdAt   DateTime @default(now())
}

// --- ATTEMPTS ---
model Attempt {
  id        String   @id @default(uuid())
  userId    String
  type      String
  score     Int      @default(0)
  content   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- ENUMS ---
enum UserRole {
  USER
  CURATOR
  SUPER_ADMIN
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  PAYPAL
}

enum SparkCategory {
  SPARK
  JOURNEY
}

enum ContentType {
  LESSON_NODE
  MEDIA
}

enum ContentStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum ExerciseType {
  MULTIPLE_CHOICE
  PHRASE_MATCHING
  TRANSLATION
  FILL_IN_BLANK
  SENTENCE_ORDER
  AI_CONVERSATION
}

enum SubStatus {
  TRIAL_ACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
}