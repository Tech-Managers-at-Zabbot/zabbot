generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                   @id @default(cuid())
  name            String?
  email           String                   @unique
  emailVerified   DateTime?
  image           String?
  avatarUrl       String?
  role            UserRole                 @default(USER)
  status          UserStatus               @default(ACTIVE)
  xp              Int                      @default(0)
  hearts          Int                      @default(5)
  currentStreak   Int                      @default(0)
  longestStreak   Int                      @default(0)
  streakFreezes   Int                      @default(0)
  isStreakFrozen  Boolean                  @default(false)
  lastStreakDate  DateTime?
  bestParaScore   Int                      @default(0)
  paraRankTitle   String?
  lastActive      DateTime?
  themePreference String                   @default("light")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  deletedAt       DateTime?
  isOnboarded     Boolean                  @default(false)
  password        String?
  conversations   AIConversationLog[]
  aiSessions      AIConversationSession[]
  accounts        Account[]
  activityLogs    ActivityLog[]
  attempts        Attempt[]
  auditLogs       AuditLog[]               @relation("Initiator")
  flashcards      Flashcard[]
  sessions        Session[]
  sparkSessions   SparkSession[]
  subscription    Subscription?
  achievements    UserAchievement[]
  journeyProgress UserJourneyProgress[]
  progress        UserLessonProgress[]
  vocabulary      UserVocabularyProgress[]
  xpTransactions  XpTransaction[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Journey {
  id             String                @id @default(uuid())
  title          String
  description    String?
  imageThumbnail String?
  icon           String?
  color          String?               @default("#162B6E")
  order          Int
  status         ContentStatus         @default(DRAFT)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  slug           String                @unique
  Media          Media[]
  sparks         Spark[]
  userProgress   UserJourneyProgress[]
  xpTransactions XpTransaction[]
}

model Spark {
  id              String               @id @default(uuid())
  journeyId       String?
  order           Int                  @default(1)
  title           String
  slug            String               @unique
  description     String?
  category        SparkCategory        @default(LANGUAGE)
  difficulty      Difficulty           @default(BEGINNER)
  xpReward        Int                  @default(50)
  imageThumbnail  String?
  isPublished     Boolean              @default(false)
  timeEstimate    Int?                 @default(5)
  status          ContentStatus        @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  icon            String?
  themeColor      String?              @default("#24A5EE")
  contentBlocks   ContentBlock[]
  exercises       Exercise[]
  media           Media[]
  journey         Journey?             @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  sessions        SparkSession[]
  sparkVocabulary SparkVocabulary[]
  userProgress    UserLessonProgress[]
  vocabulary      Vocabulary[]
  xpTransactions  XpTransaction[]

  @@index([journeyId])
  @@index([status])
}

model SparkVocabulary {
  id           String     @id @default(uuid())
  sparkId      String
  vocabularyId String
  spark        Spark      @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([sparkId, vocabularyId])
  @@index([sparkId])
  @@index([vocabularyId])
}

model ContentBlock {
  id          String      @id @default(uuid())
  type        ContentType
  order       Int         @default(0)
  yoruba      String?
  translation String?
  grammar     String?
  audioUrl    String?
  videoUrl    String?
  fileUrl     String?
  sparkId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  spark       Spark       @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([sparkId])
}

model Exercise {
  id            String       @id @default(uuid())
  type          ExerciseType @default(MULTIPLE_CHOICE)
  question      String
  options       String[]
  optionsMeta   Json?
  correctIndex  Int          @default(0)
  correctAnswer String?
  explanation   String?
  sparkId       String
  spark         Spark        @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([sparkId])
}

model Media {
  id        String    @id @default(uuid())
  url       String
  type      MediaType
  alt       String?
  createdAt DateTime  @default(now())
  journeyId String?
  sparkId   String?
  journey   Journey?  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  spark     Spark?    @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([sparkId])
}

model UserLessonProgress {
  id           String    @id @default(uuid())
  userId       String
  sparkId      String
  score        Int       @default(0)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  currentIndex Int       @default(0)
  updatedAt    DateTime  @updatedAt
  spark        Spark     @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sparkId])
}

model UserJourneyProgress {
  id          String    @id @default(uuid())
  userId      String
  journeyId   String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  journey     Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, journeyId])
}

model Vocabulary {
  id                 String                   @id @default(uuid())
  yorubaWord         String                   @unique
  englishTranslation String                   @default("")
  exampleSentence    String?
  tones              String?
  maleAudioUrl       String?
  femaleAudioUrl     String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?
  sparkId            String?
  phonemeStamps      PhonemeStamp[]
  SparkVocabulary    SparkVocabulary[]
  userProgress       UserVocabularyProgress[]
  spark              Spark?                   @relation(fields: [sparkId], references: [id], onDelete: Cascade)

  @@index([sparkId])
  @@index([yorubaWord])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

model PhonemeStamp {
  id         String     @id @default(uuid())
  vocabId    String
  syllable   String
  startTime  Float      @default(0)
  endTime    Float      @default(0)
  toneType   String
  vocabulary Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                     String          @id @default(uuid())
  userId                 String          @unique
  provider               PaymentProvider
  providerCustomerId     String?
  providerSubscriptionId String?
  plan                   String?
  status                 SubStatus       @default(TRIAL_ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TodaysWord {
  id          String   @id @default(uuid())
  word        String   @unique
  phonetic    String
  meaning     String
  displayDate DateTime @unique
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  xpGained  Int
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id           String   @id @default(uuid())
  userId       String
  front        String
  back         String
  masteryLevel Int      @default(0)
  nextReview   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, back])
}

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  source    String
  sparkId   String?
  journeyId String?
  createdAt DateTime @default(now())
  journey   Journey? @relation(fields: [journeyId], references: [id])
  spark     Spark?   @relation(fields: [sparkId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SparkSession {
  id        String   @id @default(uuid())
  userId    String
  sparkId   String
  startedAt DateTime @default(now())
  completed Boolean  @default(false)
  spark     Spark    @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIConversationSession {
  id        String              @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime            @default(now())
  logs      AIConversationLog[]
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIConversationLog {
  id        String                @id @default(uuid())
  userId    String
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime              @default(now())
  session   AIConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attempt {
  id        String   @id @default(uuid())
  userId    String
  type      String
  score     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  status    String
  timestamp DateTime @default(now())
  userId    String
  metadata  Json?
  user      User     @relation("Initiator", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Achievement {
  id               String            @id @default(uuid())
  title            String
  xpValue          Int               @default(100)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserVocabularyProgress {
  id           String     @id @default(uuid())
  userId       String
  vocabularyId String
  masteryLevel Int        @default(0)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
}

enum UserRole {
  USER
  CURATOR
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  PAYPAL
}

enum ContentType {
  LESSON_NODE
  MEDIA
  TEXT
  AUDIO
  VIDEO
}

enum ContentStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum SparkCategory {
  CULTURE
  LANGUAGE
  STORYTELLING
  GRAMMAR
  PRACTICE
}

enum ExerciseType {
  MULTIPLE_CHOICE
  PHRASE_MATCHING
  TRANSLATION
  FILL_IN_BLANK
  SENTENCE_ORDER
  AI_CONVERSATION
}

enum SubStatus {
  TRIAL_ACTIVE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ChatRole {
  USER
  AI
  SYSTEM
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}
