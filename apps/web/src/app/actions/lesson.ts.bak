"use server";

import { db } from "@/lib/db";
import { auth } from "@clerk/nextjs/server";
import { revalidatePath } from "next/cache";
import { createFlashcardsFromLesson } from "./flashcards";

interface CompleteLessonProps {
  sparkId: string;
  xpGained: number;
  finalHearts: number;
}

export async function completeLesson({
  sparkId,
  xpGained,
  finalHearts,
}: CompleteLessonProps) {
  const { userId: clerkId } = await auth();
  if (!clerkId) throw new Error("Unauthorized");

  try {
    const user = await db.user.findUnique({
      where: { clerkId },
      select: { id: true },
    });

    if (!user) throw new Error("User not found");

    // Atomic transaction for data integrity (XP, Progress, Logs)
    await db.$transaction([
      // 1. Update User XP and Health
      db.user.update({
        where: { id: user.id },
        data: {
          xp: { increment: xpGained },
          hearts: finalHearts, 
          lastActive: new Date(),
        },
      }),

      // 2. Upsert Lesson Progress
      db.userLessonProgress.upsert({
        where: {
          userId_sparkId: {
            userId: user.id,
            sparkId: sparkId,
          },
        },
        update: {
          completed: true,
          completedAt: new Date(),
          score: xpGained,
        },
        create: {
          userId: user.id,
          sparkId: sparkId,
          completed: true,
          completedAt: new Date(),
          score: xpGained,
        },
      }),

      // 3. Activity Logging (For Leaderboard Phase 5)
      db.activityLog.create({
        data: {
          userId: user.id,
          xpGained: xpGained,
          type: "LESSON_COMPLETION",
        },
      }),
    ]);

    // 4. Trigger Flashcard Injection
    // This happens outside the transaction but before revalidation 
    // to ensure the user sees their new cards immediately.
    await createFlashcardsFromLesson(sparkId);

    // Refresh data across the dashboard
    revalidatePath("/dashboard");
    revalidatePath("/dashboard/journeys");
    revalidatePath("/dashboard/learn/[id]", "page");
    
    return { success: true };
  } catch (error) {
    console.error("CRITICAL_LESSON_SYNC_ERROR:", error);
    return { success: false, error: "Failed to finalize mastery path." };
  }
}