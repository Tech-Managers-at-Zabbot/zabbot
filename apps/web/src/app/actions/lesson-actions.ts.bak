"use server";

import { db } from "@/lib/db";
import { auth } from "@clerk/nextjs/server";
import { revalidatePath } from "next/cache";

export async function completeLesson(sparkId: string, xpEarned: number) {
  // 1. Clerk Async Fix
  const { userId: clerkId } = await auth();
  if (!clerkId) throw new Error("Unauthorized");

  try {
    const result = await db.$transaction(async (tx) => {
      // 2. Find User by Clerk ID
      const user = await tx.user.findUnique({
        where: { clerkId },
      });
      if (!user) throw new Error("User not found");

      // 3. Updated model name from 'lesson' to 'spark'
      const spark = await tx.spark.findUnique({
        where: { id: sparkId },
      });
      if (!spark) throw new Error("Spark not found");

      // 4. Update Progress (using userId_sparkId unique constraint)
      await tx.userLessonProgress.upsert({
        where: {
          userId_sparkId: { userId: user.id, sparkId: spark.id },
        },
        update: {
          completed: true,
          completedAt: new Date(),
          score: 100,
        },
        create: {
          userId: user.id,
          sparkId: spark.id,
          completed: true,
          completedAt: new Date(),
          score: 100,
        },
      });

      // 5. Update User XP
      const updatedUser = await tx.user.update({
        where: { id: user.id },
        data: {
          xp: { increment: xpEarned },
        },
      });

      return updatedUser;
    });

    revalidatePath("/dashboard/journeys");
    return { success: true, xp: result.xp };
  } catch (error) {
    console.error("COMPLETE_LESSON_ERROR", error);
    return { success: false, error: "Failed to save progress." };
  }
}