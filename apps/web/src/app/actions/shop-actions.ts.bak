"use server";

import { db } from "@/lib/db";
import { auth } from "@clerk/nextjs/server"; 
import { revalidatePath } from "next/cache";

const FREEZE_COST = 200;

export async function buyStreakFreeze() {
    // 1. Await auth() - Required for Next.js 16
    const { userId } = await auth();
    if (!userId) throw new Error("Unauthorized");

    // 2. Find user by clerkId (per your schema @@index([clerkId]))
    const user = await db.user.findUnique({
        where: { clerkId: userId },
    });

    if (!user) throw new Error("User not found in database");

    if (user.xp < FREEZE_COST) {
        return { success: false, message: "Not enough XP!" };
    }

    await db.user.update({
        where: { id: user.id },
        data: {
            xp: { decrement: FREEZE_COST },
            streakFreezes: { increment: 1 },
        },
    });

    revalidatePath("/dashboard");
    return { success: true, message: "Purchase successful!" };
}