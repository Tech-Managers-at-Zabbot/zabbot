"use server";

import { v2 as cloudinary } from "cloudinary";
import { db } from "@/lib/db";;
import { revalidatePath } from "next/cache";

// Configure Cloudinary
cloudinary.config({
    cloud_name: process.env.CLOUDINARY_CLOUD_NAME,
    api_key: process.env.CLOUDINARY_API_KEY,
    api_secret: process.env.CLOUDINARY_API_SECRET,
});

export async function uploadParaContent(formData: FormData) {
    try {
        const yorubaWord = formData.get("yorubaWord") as string;
        const englishTranslation = formData.get("englishTranslation") as string;
        const lessonId = formData.get("lessonId") as string;
        const file = formData.get("audioFile") as File;

        if (!file || file.size === 0) {
            throw new Error("No valid audio file provided");
        }

        // 1. Convert File to Buffer
        const arrayBuffer = await file.arrayBuffer();
        const buffer = Buffer.from(arrayBuffer);

        // 2. Upload to Cloudinary
        // We sanitize the yorubaWord for the URL to avoid breaking Cloudinary paths
        const sanitizedName = yorubaWord
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "") // Remove Yorùbá tone marks for the filename only
            .replace(/\s+/g, '-')
            .toLowerCase();

        const uploadResponse = await new Promise((resolve, reject) => {
            const uploadStream = cloudinary.uploader.upload_stream(
                {
                    resource_type: "video", // Required for audio files in Cloudinary
                    folder: "zabbot/para",
                    public_id: `${Date.now()}-${sanitizedName}`,
                },
                (error, result) => {
                    if (error) reject(error);
                    else resolve(result);
                }
            );
            uploadStream.end(buffer);
        }) as any;

        /**
         * 3. Save to Prisma
         * CRITICAL: Ensure 'lessonId' and 'yorubaWord' exist in your schema.db.
         * If your schema uses 'yorubaText', change the key below.
         */
        await db.vocabulary.create({
            data: {
                yorubaWord: yorubaWord, // Use the original word with tone marks
                englishTranslation: englishTranslation,
                audioUrl: uploadResponse.secure_url,
                // Only connect to a lesson if it's not the global pool
                ...(lessonId && lessonId !== "global-para-pool"
                    ? { lessonId: lessonId }
                    : { lessonId: null }
                ),
            },
        });

        revalidatePath("/admin/para");
        return { success: true };

    } catch (error) {
        console.error("Action Error:", error);
        return {
            success: false,
            error: error instanceof Error ? error.message : "Failed to upload content"
        };
    }
}