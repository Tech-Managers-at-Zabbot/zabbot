"use server";
import { db } from "@/lib/db"; // Use consistent 'db' export
import { revalidatePath } from "next/cache";

export async function completeLesson(userId: string, sparkId: string) {
  try {
    // 1. Record the completion (using sparkId from your schema)
    await db.userLessonProgress.upsert({
      where: {
        userId_sparkId: { userId, sparkId }, // Fixed unique constraint name
      },
      update: {
        completed: true,
        completedAt: new Date(),
        score: 100,
      },
      create: {
        userId,
        sparkId, // Fixed field name
        completed: true,
        completedAt: new Date(),
        score: 100,
      },
    });

    // 2. Award XP
    await db.user.update({
      where: { id: userId },
      data: {
        xp: { increment: 50 },
      },
    });

    revalidatePath("/dashboard/journeys");
    return { success: true };
  } catch (error) {
    console.error("Progress Error:", error);
    return { success: false };
  }
}