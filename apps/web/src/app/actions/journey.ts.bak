"use server";

import { db } from "@/lib/db";
import { auth } from "@clerk/nextjs/server";
import { revalidatePath } from "next/cache";
import { ContentStatus, ContentType, ExerciseType } from "@prisma/client";

export async function publishJourney(courseData: any[]) {
  const { userId } = await auth();
  if (!userId) throw new Error("Unauthorized");

  try {
    const data = courseData[0];

    const result = await db.$transaction(async (tx) => {
      // 1. Upsert Journey Level
      const journey = await tx.journey.upsert({
        where: { id: data.id || "new-journey-id" }, 
        update: {
          description: data.description,
          imageThumbnail: data.heroImage,
          status: ContentStatus.PUBLISHED,
        },
        create: {
          title: data.title,
          description: data.description,
          imageThumbnail: data.heroImage,
          status: ContentStatus.PUBLISHED,
          order: 0, 
        },
      });

      // 2. Create a default Spark for this journey (since Sparks hold the content)
      const spark = await tx.spark.upsert({
        where: { slug: `${journey.id}-main`.toLowerCase() },
        update: { title: data.title },
        create: {
          journeyId: journey.id,
          title: data.title,
          slug: `${journey.id}-main`.toLowerCase(),
          status: ContentStatus.PUBLISHED,
          isPublished: true,
          order: 1,
        }
      });

      // 3. Clear old relations using sparkId
      await tx.contentBlock.deleteMany({ where: { sparkId: spark.id } });
      await tx.exercise.deleteMany({ where: { sparkId: spark.id } });

      // 4. Map Content Blocks
      await tx.contentBlock.createMany({
        data: data.contentBlocks.map((block: any, index: number) => ({
          sparkId: spark.id,
          order: index,
          type: ContentType.LESSON_NODE,
          yoruba: block.yoruba || block.title,
          english: block.english || block.content,
          audioUrl: block.audioUrl,
          videoUrl: block.videoUrl,
        })),
      });

      // 5. Map Quizzes
      await tx.exercise.createMany({
        data: data.quizzes.map((q: any) => ({
          sparkId: spark.id,
          type: ExerciseType.MULTIPLE_CHOICE,
          question: q.question,
          options: q.options,
          correctIndex: q.correctIndex || 0,
        })),
      });

      return journey;
    });

    revalidatePath("/dashboard/journey");
    return { success: true, id: result.id };
  } catch (error) {
    console.error("JOURNEY_PUBLISH_ERROR", error);
    return { success: false, error: "Database sync failed." };
  }
}