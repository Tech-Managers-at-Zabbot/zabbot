"use server";

import { db } from "@/lib/db";
import { revalidatePath } from "next/cache";
// 1. Corrected Import for Next.js 16
import { auth } from "@clerk/nextjs/server";
import { ContentStatus, ContentType, SparkCategory, ExerciseType } from "@prisma/client";

export async function upsertJourneyLesson(data: {
  id?: string;
  order: number;
  title: string;
  description: string;
  difficulty: string;
  nodes: Array<{ yoruba: string; english: string; notes?: string; audioUrl?: string }>;
  quiz: { question: string; correctAnswer: string; options: string[] };
}) {
  // 2. Await the auth helper (Clerk v6/v7 requirement)
  const { userId } = await auth();
  if (!userId) throw new Error("Unauthorized");

  try {
    const result = await db.$transaction(async (tx) => {
      // 3. Upsert Journey (mapped from data.order)
      const journey = await tx.journey.upsert({
        where: { id: data.id || "temp-id-placeholder" }, // Best to use id if available
        update: {
          title: data.title,
          description: data.description,
          order: data.order,
          status: ContentStatus.PUBLISHED,
        },
        create: {
          title: data.title,
          description: data.description,
          order: data.order,
          status: ContentStatus.PUBLISHED,
        },
      });

      // 4. Upsert a Spark (The actual lesson content)
      // We'll target the first spark for this journey based on the order
      const spark = await tx.spark.upsert({
        where: { 
          slug: `${journey.id}-spark-1`.toLowerCase().replace(/\s+/g, '-') 
        },
        update: {
          title: data.title,
          difficulty: data.difficulty,
          status: ContentStatus.PUBLISHED,
          isPublished: true,
        },
        create: {
          journeyId: journey.id,
          title: data.title,
          slug: `${journey.id}-spark-1`.toLowerCase().replace(/\s+/g, '-'),
          difficulty: data.difficulty,
          category: SparkCategory.JOURNEY,
          status: ContentStatus.PUBLISHED,
          isPublished: true,
          order: 1,
        },
      });

      // 5. Replace Content Blocks (The Nodes)
      await tx.contentBlock.deleteMany({ where: { sparkId: spark.id } });
      await tx.contentBlock.createMany({
        data: data.nodes.map((node, index) => ({
          sparkId: spark.id,
          order: index,
          type: ContentType.LESSON_NODE, // Required by your schema
          yoruba: node.yoruba,
          english: node.english,
          grammar: node.notes, // Mapped 'notes' to 'grammar' per schema
          audioUrl: node.audioUrl,
        })),
      });

      // 6. Replace Exercises
      await tx.exercise.deleteMany({ where: { sparkId: spark.id } });
      await tx.exercise.create({
        data: {
          sparkId: spark.id,
          type: ExerciseType.MULTIPLE_CHOICE,
          question: data.quiz.question,
          options: data.quiz.options,
          // Note: Your schema has 'correctIndex' (Int) but the incoming data has 'correctAnswer' (String)
          // We default to index 0 or you may need to find the index of the answer in options.
          correctIndex: data.quiz.options.indexOf(data.quiz.correctAnswer) || 0,
        },
      });

      return journey;
    });

    revalidatePath("/dashboard/journeys");
    return { success: true, id: result.id };
  } catch (error) {
    console.error("ADMIN_UPSERT_ERROR", error);
    return { success: false, error: "Failed to populate journey." };
  }
}