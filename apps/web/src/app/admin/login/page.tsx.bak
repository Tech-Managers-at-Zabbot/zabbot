"use client";

import React, { useState } from "react";
import { motion } from "framer-motion";
import { Lock, ShieldCheck, Eye, EyeOff, ArrowRight } from "lucide-react";
import { ZabbotMascot } from "@/components/shared/ZabbotMascot";

export default function GuardianLogin() {
    const [showPassword, setShowPassword] = useState(false);
    const [isLoading, setIsLoading] = useState(false);

    const handleLogin = (e: React.FormEvent) => {
        e.preventDefault();
        setIsLoading(true);
        // Logic for Role-Based Access (Content Admin vs Super-Admin)
        setTimeout(() => setIsLoading(false), 2000);
    };

    return (
        <div className="min-h-screen flex items-center justify-center bg-[#EFF6FF] dark:bg-[#0F1117] p-6 font-inter transition-colors duration-300">
            <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                className="w-full max-w-md"
            >
                {/* Brand Identity Section */}
                <div className="text-center mb-10">
                    <ZabbotMascot mood="welcoming" size={140} className="mx-auto mb-4" />

                    <h1 className="text-3xl font-bold font-poppins text-[#162B6E] dark:text-[#24A5EE]">
                        Guardian Gate
                    </h1>
                    <p className="text-[#64748B] dark:text-[#B5B8C5] mt-2">
                        Secure access to Zabbot Heritage Studio
                    </p>
                </div>

                {/* Login Card */}
                <div className="bg-white dark:bg-[#1F222A] p-8 rounded-[16px] shadow-premium border border-[#E2E8F0] dark:border-[#2A2E39]">
                    <form onSubmit={handleLogin} className="space-y-6">
                        <div>
                            <label className="block text-xs font-bold tracking-widest text-[#64748B] dark:text-[#B5B8C5] uppercase mb-2">
                                Guardian ID
                            </label>
                            <div className="relative">
                                <input
                                    type="text"
                                    placeholder="Enter your ID"
                                    className="w-full bg-[#F8FAFC] dark:bg-[#181A20] p-4 pl-12 rounded-[12px] border border-[#E2E8F0] dark:border-[#2A2E39] focus:ring-2 focus:ring-[#24A5EE] outline-none transition-all"
                                />
                                <ShieldCheck className="absolute left-4 top-1/2 -translate-y-1/2 text-[#24A5EE]" size={20} />
                            </div>
                        </div>

                        <div>
                            <label className="block text-xs font-bold tracking-widest text-[#64748B] dark:text-[#B5B8C5] uppercase mb-2">
                                Security Key
                            </label>
                            <div className="relative">
                                <input
                                    type={showPassword ? "text" : "password"}
                                    placeholder="••••••••"
                                    className="w-full bg-[#F8FAFC] dark:bg-[#181A20] p-4 pl-12 rounded-[12px] border border-[#E2E8F0] dark:border-[#2A2E39] focus:ring-2 focus:ring-[#24A5EE] outline-none transition-all"
                                />
                                <Lock className="absolute left-4 top-1/2 -translate-y-1/2 text-[#24A5EE]" size={20} />
                                <button
                                    type="button"
                                    onClick={() => setShowPassword(!showPassword)}
                                    className="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-[#24A5EE]"
                                >
                                    {showPassword ? <EyeOff size={18} /> : <Eye size={18} />}
                                </button>
                            </div>
                        </div>

                        <button
                            type="submit"
                            disabled={isLoading}
                            className="w-full py-4 bg-[#162B6E] hover:bg-[#0F172A] text-white font-bold rounded-[12px] shadow-lg transition-all flex items-center justify-center gap-2 group active:scale-95"
                        >
                            {isLoading ? (
                                <div className="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                            ) : (
                                <>
                                    Unlock Studio
                                    <ArrowRight size={18} className="group-hover:translate-x-1 transition-transform" />
                                </>
                            )}
                        </button>
                    </form>

                    <div className="mt-8 pt-6 border-t border-[#E2E8F0] dark:border-[#2A2E39] text-center">
                        <p className="text-xs text-[#64748B] dark:text-[#B5B8C5] leading-relaxed">
                            Authorized personnel only. All access attempts are logged in the
                            <span className="text-[#162B6E] dark:text-[#24A5EE] font-bold"> Heritage Archive</span>.
                        </p>
                    </div>
                </div>

                <div className="mt-6 text-center">
                    <button className="text-sm text-[#64748B] hover:text-[#162B6E] dark:hover:text-[#24A5EE] font-medium transition-colors">
                        Forgot Security Key?
                    </button>
                </div>
            </motion.div>
        </div>
    );
}