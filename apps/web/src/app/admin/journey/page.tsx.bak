"use client";

import React, { useState, useEffect, Suspense } from "react"; // Added Suspense
import { useRouter, useSearchParams } from "next/navigation";
import { 
  Trash2, Mic, Video, FileText, Image as ImageIcon, 
  HelpCircle, CheckCircle, UploadCloud,
  Loader2, AlertCircle, BookOpen, X, Plus, Clock
} from "lucide-react";
import { CldUploadWidget } from 'next-cloudinary';
import { AdminInput, AdminTextArea } from "@/components/admin/StudioUI";
import { publishJourney, getJourneyById } from "./actions";

// --- 1. THE CONTENT COMPONENT ---
function JourneyArchitectContent() {
  const router = useRouter();
  const searchParams = useSearchParams();
  const journeyId = searchParams.get("id");

  const [isPublishing, setIsPublishing] = useState(false);
  
  const [journeyData, setJourneyData] = useState({
    id: null as string | null,
    title: "",
    description: "",
    imageThumbnail: "", 
    order: 1,           
    lessons: [
      {
        title: "",
        description: "", 
        timeEstimate: 15,
        category: "JOURNEY", 
        audioUrl: "",
        videoUrl: "",
        fileUrl: "",
        quizzes: [] as any[]
      }
    ]
  });

  useEffect(() => {
    if (journeyId) {
      const loadJourney = async () => {
        const response = await getJourneyById(journeyId);
        if (response.success && response.data) {
          const d = response.data;
          setJourneyData({
            id: d.id,
            title: d.title,
            description: d.description || "",
            imageThumbnail: d.imageThumbnail || "",
            order: d.order || 1,
            lessons: d.sparks.map((s: any) => ({ 
              title: s.title,
              description: s.description,
              timeEstimate: s.timeEstimate || 15,
              category: "JOURNEY",
              audioUrl: s.contentBlocks?.[0]?.audioUrl || "",
              videoUrl: s.contentBlocks?.[0]?.videoUrl || "",
              fileUrl: s.contentBlocks?.[0]?.fileUrl || "",
              quizzes: s.exercises.map((e: any) => ({
                question: e.question,
                options: e.options,
                correctIndex: e.correctIndex
              }))
            }))
          });
        }
      };
      loadJourney();
    }
  }, [journeyId]);

  const isDataReady = journeyData.title.trim() !== "" && journeyData.imageThumbnail !== "";

  const updateJourney = (field: string, value: any) => {
    setJourneyData(prev => ({ ...prev, [field]: value }));
  };

  const updateLesson = (lIdx: number, field: string, value: any) => {
    const updatedLessons = [...journeyData.lessons];
    updatedLessons[lIdx] = { ...updatedLessons[lIdx], [field]: value };
    setJourneyData(prev => ({ ...prev, lessons: updatedLessons }));
  };

  const updateQuiz = (lIdx: number, qIdx: number, field: string, value: any) => {
    const updatedLessons = [...journeyData.lessons];
    const updatedQuizzes = [...updatedLessons[lIdx].quizzes];
    updatedQuizzes[qIdx] = { ...updatedQuizzes[qIdx], [field]: value };
    updatedLessons[lIdx].quizzes = updatedQuizzes;
    setJourneyData(prev => ({ ...prev, lessons: updatedLessons }));
  };

  const addLesson = () => {
    setJourneyData(prev => ({
      ...prev,
      lessons: [...prev.lessons, { 
        title: "", 
        description: "", 
        timeEstimate: 15, 
        category: "JOURNEY", 
        audioUrl: "", 
        videoUrl: "", 
        fileUrl: "", 
        quizzes: [] 
      }]
    }));
  };

  const handlePublish = async () => {
    if (!isDataReady) {
      alert("Please ensure you have a Title and a Hero Image uploaded.");
      return;
    }
    
    setIsPublishing(true);
    try {
      const response = await publishJourney(journeyData);
      if (response.success) {
        alert(journeyId ? "✨ Journey Updated!" : "🚀 Success! Journey is live.");
        router.push("/admin/dashboard");
        router.refresh();
      } else {
        alert(`Error: ${response.error}`);
      }
    } catch (err) {
      alert("Failed to reach the server.");
    } finally {
      setIsPublishing(false);
    }
  };

  return (
    <main className="min-h-screen bg-[#F8FAFC]">
      <header className="p-8 border-b bg-white flex justify-between items-center sticky top-0 z-30 shadow-sm">
        <div>
          <h1 className="text-3xl font-black text-[#162B6E] italic leading-tight">
            {journeyId ? "Edit Journey" : "Journey Architect"}
          </h1>
          <p className="text-[10px] font-bold text-[#24A5EE] uppercase tracking-[0.3em]">Studio Mode • V2.0</p>
        </div>
        
        <button 
          onClick={handlePublish}
          disabled={isPublishing}
          className={`px-10 py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all shadow-xl flex items-center gap-2 ${
            isPublishing ? 'bg-slate-300' : 'bg-[#162B6E] hover:bg-[#24A5EE] text-white active:scale-95'
          }`}
        >
          {isPublishing ? <><Loader2 className="animate-spin" size={14} /> Saving...</> : (journeyId ? "Update Journey" : "Publish Journey")}
        </button>
      </header>

      <div className="max-w-4xl mx-auto py-12 space-y-12 px-6">
        <section className="bg-white p-10 rounded-[40px] shadow-sm border border-slate-100 space-y-6">
          <h2 className="text-[11px] font-black text-[#162B6E] uppercase tracking-widest">1. Journey Identity</h2>
          
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div className="md:col-span-2">
              <AdminInput label="Journey Title" value={journeyData.title} onChange={(e:any) => updateJourney('title', e.target.value)} />
            </div>
            <div>
              <AdminInput label="Display Order" type="number" value={journeyData.order} onChange={(e:any) => updateJourney('order', parseInt(e.target.value) || 1)} />
            </div>
          </div>

          <AdminTextArea label="Journey Description" value={journeyData.description} onChange={(e:any) => updateJourney('description', e.target.value)} />
          
          <div className="space-y-4">
             <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Hero Image (Required)</label>
             <CldUploadWidget 
                uploadPreset={process.env.NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET} 
                onSuccess={(res: any) => updateJourney('imageThumbnail', res.info.secure_url)}
              >
                {({ open }) => (
                  <div onClick={() => open()} className="relative w-full h-48 border-2 border-dashed rounded-3xl flex items-center justify-center cursor-pointer overflow-hidden bg-slate-50 hover:border-[#24A5EE]">
                    {journeyData.imageThumbnail ? (
                      <img src={journeyData.imageThumbnail} className="w-full h-full object-cover" alt="Hero" />
                    ) : (
                      <div className="text-center">
                        <UploadCloud className="mx-auto text-slate-300 mb-2" size={32} />
                        <span className="text-[9px] font-bold text-slate-400 uppercase">Upload Hero</span>
                      </div>
                    )}
                  </div>
                )}
              </CldUploadWidget>
          </div>
        </section>

        <div className="space-y-8">
          {journeyData.lessons.map((lesson, lIdx) => (
            <div key={lIdx} className="bg-white p-8 rounded-[32px] border-l-8 border-l-[#24A5EE] shadow-sm space-y-6">
              <div className="flex justify-between items-center">
                <span className="bg-[#162B6E] text-white text-[9px] font-black px-4 py-1 rounded-full uppercase">Node {lIdx + 1}</span>
                <button onClick={() => {
                  const filtered = journeyData.lessons.filter((_, i) => i !== lIdx);
                  updateJourney('lessons', filtered);
                }} className="text-slate-200 hover:text-red-500">
                  <Trash2 size={18} />
                </button>
              </div>

              <AdminInput label="Lesson Title" value={lesson.title} onChange={(e:any) => updateLesson(lIdx, 'title', e.target.value)} />
              
              <div className="grid grid-cols-1 md:grid-cols-4 gap-6 items-end">
                <div className="md:col-span-3">
                    <AdminTextArea label="Teaching content" value={lesson.description} onChange={(e:any) => updateLesson(lIdx, 'description', e.target.value)} />
                </div>
                <div>
                    <AdminInput label="Mins" type="number" value={lesson.timeEstimate} onChange={(e:any) => updateLesson(lIdx, 'timeEstimate', parseInt(e.target.value) || 0)} />
                </div>
              </div>

              <div className="grid grid-cols-3 gap-4">
                <MediaButton icon={<Mic size={14}/>} label="Audio" url={lesson.audioUrl} onUpload={(url: string) => updateLesson(lIdx, 'audioUrl', url)} />
                <MediaButton icon={<Video size={14}/>} label="Video" url={lesson.videoUrl} onUpload={(url: string) => updateLesson(lIdx, 'videoUrl', url)} />
                <MediaButton icon={<FileText size={14}/>} label="Resource" url={lesson.fileUrl} onUpload={(url: string) => updateLesson(lIdx, 'fileUrl', url)} />
              </div>

              <div className="bg-slate-50 p-6 rounded-[24px] space-y-4">
                <h4 className="text-[10px] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
                  <HelpCircle size={14} /> Knowledge Checks ({lesson.quizzes.length})
                </h4>
                {lesson.quizzes.map((quiz, qIdx) => (
                  <div key={qIdx} className="bg-white p-4 rounded-xl border border-slate-200 space-y-3">
                    <div className="flex justify-between">
                       <span className="text-[8px] font-bold text-[#24A5EE]">QUESTION {qIdx + 1}</span>
                       <button onClick={() => {
                         const updated = lesson.quizzes.filter((_, i) => i !== qIdx);
                         updateLesson(lIdx, 'quizzes', updated);
                       }}><X size={12} className="text-slate-300" /></button>
                    </div>
                    <input className="w-full text-xs font-medium outline-none border-b focus:border-[#24A5EE]" placeholder="Question..." value={quiz.question} onChange={(e) => updateQuiz(lIdx, qIdx, 'question', e.target.value)} />
                    <div className="grid grid-cols-2 gap-2">
                      {quiz.options.map((opt: string, oIdx: number) => (
                        <div key={oIdx} className="flex items-center gap-2 bg-slate-50 p-2 rounded-lg">
                          <input type="radio" checked={quiz.correctIndex === oIdx} onChange={() => updateQuiz(lIdx, qIdx, 'correctIndex', oIdx)} />
                          <input className="bg-transparent text-[10px] outline-none w-full" placeholder={`Opt ${oIdx + 1}`} value={opt} onChange={(e) => {
                            const newOpts = [...quiz.options];
                            newOpts[oIdx] = e.target.value;
                            updateQuiz(lIdx, qIdx, 'options', newOpts);
                          }} />
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
                <button onClick={() => updateLesson(lIdx, 'quizzes', [...lesson.quizzes, { question: "", options: ["", "", "", ""], correctIndex: 0 }])} className="w-full py-3 border border-dashed rounded-xl text-[9px] font-black text-slate-400 uppercase">
                  + Add Quiz Question
                </button>
              </div>
            </div>
          ))}
          <button onClick={addLesson} className="w-full py-8 border-2 border-dashed border-slate-200 rounded-[32px] text-slate-400 flex flex-col items-center gap-2">
            <Plus size={24} />
            <span className="text-[10px] font-black uppercase">Add New Map Node</span>
          </button>
        </div>
      </div>
    </main>
  );
}

// --- 2. THE MAIN PAGE EXPORT ---
// This wraps the search params logic in a Suspense boundary to fix the build error
export default function JourneyArchitect() {
  return (
    <Suspense fallback={
      <div className="min-h-screen flex items-center justify-center bg-[#F8FAFC]">
        <div className="flex flex-col items-center gap-4">
          <Loader2 className="animate-spin text-[#24A5EE]" size={40} />
          <p className="text-[10px] font-black text-[#162B6E] uppercase tracking-widest">Initializing Architect Studio...</p>
        </div>
      </div>
    }>
      <JourneyArchitectContent />
    </Suspense>
  );
}

// --- 3. SUBCOMPONENTS ---
function MediaButton({ icon, label, url, onUpload }: any) {
  const [loading, setLoading] = useState(false);
  return (
    <CldUploadWidget 
      uploadPreset={process.env.NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET} 
      onOpen={() => setLoading(true)}
      onSuccess={(res: any) => { setLoading(false); onUpload(res.info.secure_url); }}
      onQueuesEnd={() => setLoading(false)}
    >
      {({ open }) => (
        <button onClick={() => open()} className={`flex flex-col items-center justify-center p-6 rounded-3xl border-2 border-dashed relative ${url ? 'border-green-500 bg-green-50 text-green-600' : 'border-slate-100 text-slate-400 hover:border-[#24A5EE]'}`}>
          {loading && <div className="absolute inset-0 bg-white/60 flex items-center justify-center"><Loader2 size={16} className="animate-spin text-[#24A5EE]" /></div>}
          {url ? <CheckCircle size={18} /> : icon}
          <span className="text-[8px] font-black uppercase mt-2">{url ? "Verified" : `Add ${label}`}</span>
        </button>
      )}
    </CldUploadWidget>
  );
}