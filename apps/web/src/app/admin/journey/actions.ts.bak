"use server";

import { db } from "@/lib/db";
import { SparkCategory, ContentStatus, ContentType, ExerciseType } from "@prisma/client"; 
import { revalidatePath } from "next/cache";

/**
 * FETCH JOURNEY BY ID
 * Hydrates the Journey Architect with all nested lessons and quizzes.
 */
export async function getJourneyById(id: string) {
  try {
    const journey = await db.journey.findUnique({
      where: { id },
      include: {
        sparks: {
          orderBy: { order: 'asc' },
          include: {
            contentBlocks: {
              orderBy: { order: 'asc' },
            },
            // FIX: Removed 'orderBy: order' because Exercise model lacks an 'order' field
            exercises: true, 
          },
        },
      },
    });

    if (!journey) return { success: false, error: "Journey not found" };

    return { success: true, data: journey };
  } catch (error: any) {
    console.error("GET_JOURNEY_ERROR:", error);
    return { success: false, error: "Failed to fetch journey data" };
  }
}

/**
 * PUBLISH / UPDATE JOURNEY
 * Handles the nested synchronization of Sparks, ContentBlocks, and Exercises.
 */
export async function publishJourney(data: any) {
  try {
    const result = await db.$transaction(async (tx) => {
      let journeyId = data.id;

      // 1. JOURNEY UPSERT
      if (journeyId) {
        await tx.journey.update({
          where: { id: journeyId },
          data: {
            title: data.title,
            description: data.description,
            imageThumbnail: data.imageThumbnail,
            order: parseInt(data.order) || 1,
            status: ContentStatus.PUBLISHED,
          }
        });
        
        // Clear existing Sparks to avoid relational conflicts during update
        await tx.spark.deleteMany({ where: { journeyId } });
      } else {
        const newJourney = await tx.journey.create({
          data: {
            title: data.title,
            description: data.description || "",
            imageThumbnail: data.imageThumbnail,
            order: parseInt(data.order) || 1,
            status: ContentStatus.PUBLISHED,
          },
        });
        journeyId = newJourney.id;
      }

      // 2. CREATE SPARKS (MASTER_PATH NODES)
      for (let i = 0; i < data.lessons.length; i++) {
        const lesson = data.lessons[i];
        
        const cleanJourneyTitle = data.title.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
        const cleanLessonTitle = (lesson.title || `module-${i+1}`).toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
        const uniqueSlug = `${cleanJourneyTitle}-${cleanLessonTitle}-${Date.now().toString().slice(-4)}`;

        await tx.spark.create({
          data: {
            journeyId: journeyId,
            title: lesson.title || `Module ${i + 1}`,
            description: lesson.description || "",
            imageThumbnail: data.imageThumbnail, 
            order: i + 1,
            xpReward: 100,
            timeEstimate: parseInt(lesson.timeEstimate) || 15,
            category: SparkCategory.JOURNEY,
            status: ContentStatus.PUBLISHED,
            isPublished: true,
            slug: uniqueSlug,
            contentBlocks: {
              create: {
                order: 1,
                type: ContentType.LESSON_NODE,
                yoruba: lesson.title,
                english: lesson.description, 
                audioUrl: lesson.audioUrl || "",
                videoUrl: lesson.videoUrl || "",
              }
            },
            exercises: {
              create: (lesson.quizzes || []).map((q: any) => ({
                question: q.question,
                options: q.options,
                correctIndex: q.correctIndex,
                type: ExerciseType.MULTIPLE_CHOICE,
              }))
            }
          },
        });
      }
      return { id: journeyId };
    }, { timeout: 30000 });

    revalidatePath("/admin/dashboard");
    revalidatePath("/dashboard"); 
    
    return { success: true, journeyId: result.id };
  } catch (error: any) {
    console.error("JOURNEY_PUBLISH_ERROR:", error);
    return { success: false, error: error.message };
  }
}

/**
 * DELETE JOURNEY
 */
export async function deleteJourney(id: string) {
  try {
    await db.journey.delete({ where: { id } });
    revalidatePath("/admin/dashboard");
    revalidatePath("/dashboard");
    return { success: true };
  } catch (error: any) {
    console.error("DELETE_JOURNEY_ERROR:", error);
    return { success: false, error: error.message };
  }
}