"use server";

import { db } from "@/lib/db";
import { auth } from "@clerk/nextjs/server";
import { SparkCategory, ContentStatus, ContentType } from "@prisma/client";
import { revalidatePath } from "next/cache";

/**
 * DELETE SPARK
 */
export async function deleteSpark(sparkId: string) {
  try {
    const { userId } = await auth();
    if (!userId) throw new Error("Unauthorized");

    await db.contentBlock.deleteMany({ where: { sparkId } });
    await db.exercise.deleteMany({ where: { sparkId } });
    
    await db.spark.delete({
      where: { id: sparkId },
    });

    revalidatePath("/admin/archive");
    revalidatePath("/dashboard");

    return { success: true };
  } catch (error: any) {
    console.error("Delete Error:", error);
    return { success: false, message: error.message || "Failed to delete spark" };
  }
}

/**
 * CREATE FULL SPARK
 */
export async function createFullSpark(prevState: any, formData: FormData) {
  try {
    // 1. Clerk Async Fix
    const { userId: clerkId } = await auth();
    if (!clerkId) throw new Error("Unauthorized");

    const title = (formData.get("title") as string) || "Untitled Spark";
    
    // Unique slug generation
    const baseSlug = title.toLowerCase().trim().replace(/[^\w\s-]/g, '').replace(/[\s_-]+/g, '-');
    const slug = `${baseSlug}-${Date.now().toString().slice(-4)}`;

    const spark = await db.spark.create({
      data: {
        title,
        slug,
        description: formData.get("description") as string,
        imageThumbnail: formData.get("imageThumbnail") as string,
        timeEstimate: parseInt(formData.get("timeEstimate") as string) || 5,
        xpReward: parseInt(formData.get("xpReward") as string) || 50,
        category: SparkCategory.SPARK,
        order: parseInt(formData.get("order") as string) || 1,
        
        // 2. FIX: Correct Enum for status
        status: ContentStatus.PUBLISHED, 
        isPublished: true,

        // 3. Metadata fields
        proverb_yoruba: formData.get("proverb_yoruba") as string,
        proverb_english: formData.get("proverb_english") as string,
        honorific_rule: formData.get("honorific_rule") as string,

        // 4. Content Blocks Mapping
        contentBlocks: {
          create: JSON.parse((formData.get("nodes_data") as string) || "[]").map((node: any, i: number) => ({
            order: i + 1,
            type: ContentType.LESSON_NODE,
            yoruba: node.yoruba,   // Correct field name from schema
            english: node.english, // Correct field name from schema
            audioUrl: node.audio || "",
          })),
        },
      },
    });

    revalidatePath('/admin/archive');
    revalidatePath('/dashboard');

    return { success: true };
  } catch (error: any) {
    console.error("Upload Error:", error);
    return { success: false, message: error.message };
  }
}