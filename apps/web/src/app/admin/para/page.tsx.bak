"use client";

import React, { useState, useEffect } from "react";
import { motion, AnimatePresence } from "framer-motion";
import {
    Upload,
    Music,
    Play,
    Pause,
    Scissors,
    Save,
    ArrowRight,
    X
} from "lucide-react";
import { ZabbotMascot } from "@/components/shared/ZabbotMascot";

export default function ParaAudioLab() {
    const [file, setFile] = useState<File | null>(null);
    const [uploading, setUploading] = useState(false);
    const [view, setView] = useState<"upload" | "sync">("upload");
    const [isPlaying, setIsPlaying] = useState(false);
    const [stamps, setStamps] = useState([
        { word: "Báwo", start: "0:01", end: "0:03" },
        { word: "ni", start: "0:04", end: "0:05" },
    ]);

    const handleStartSync = (e: React.FormEvent) => {
        e.preventDefault();
        setUploading(true);
        // Simulate upload processing
        setTimeout(() => {
            setUploading(false);
            setView("sync");
        }, 1500);
    };

    return (
        <div className="min-h-screen bg-[#F8FAFC] dark:bg-[#0F1117] p-8 ml-72 transition-colors duration-300">
            <div className="max-w-6xl mx-auto">

                <header className="mb-10 flex justify-between items-end">
                    <div>
                        <h1 className="text-4xl font-bold font-poppins text-[#162B6E] dark:text-white">
                            Pàrà <span className="text-[#24A5EE]">Audio Lab</span>
                        </h1>
                        <p className="text-[#64748B] dark:text-[#B5B8C5] mt-1 font-medium">
                            {view === "upload" ? "Upload native recordings to the vault." : "Precise phoneme mapping & tonal synchronization."}
                        </p>
                    </div>
                    {view === "sync" && (
                        <button className="px-6 py-3 bg-[#162B6E] text-white rounded-xl text-sm font-bold shadow-premium flex items-center gap-2 hover:bg-[#0F172A] transition-all active:scale-95">
                            <Save size={18} /> Sync to Lesson Tree
                        </button>
                    )}
                </header>

                <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <div className="lg:col-span-8">
                        <AnimatePresence mode="wait">
                            {view === "upload" ? (
                                <motion.div
                                    key="upload"
                                    initial={{ opacity: 0, y: 20 }}
                                    animate={{ opacity: 1, y: 0 }}
                                    exit={{ opacity: 0, y: -20 }}
                                    className="bg-white dark:bg-[#1F222A] rounded-[32px] p-10 shadow-premium border border-[#E2E8F0] dark:border-[#2A2E39]"
                                >
                                    <form onSubmit={handleStartSync} className="space-y-8">
                                        <div className="grid grid-cols-1 md:grid-cols-2 gap-10">
                                            <div className="space-y-5">
                                                <div>
                                                    <label className="text-[10px] font-black tracking-widest text-[#64748B] uppercase mb-2 block">Yorùbá Phrase</label>
                                                    <input type="text" placeholder="e.g. Ẹ kú àárọ̀" className="w-full bg-[#F8FAFC] dark:bg-[#181A20] p-4 rounded-xl border border-[#E2E8F0] dark:border-[#2A2E39] outline-none text-lg font-bold focus:ring-2 focus:ring-[#24A5EE]/20 transition-all" />
                                                </div>
                                                <div>
                                                    <label className="text-[10px] font-black tracking-widest text-[#64748B] uppercase mb-2 block">English Translation</label>
                                                    <input type="text" placeholder="e.g. Good morning" className="w-full bg-[#F8FAFC] dark:bg-[#181A20] p-4 rounded-xl border border-[#E2E8F0] dark:border-[#2A2E39] outline-none focus:ring-2 focus:ring-[#24A5EE]/20 transition-all" />
                                                </div>
                                            </div>
                                            <div className="relative group">
                                                <input type="file" className="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onChange={(e) => setFile(e.target.files?.[0] || null)} />
                                                <div className="h-full border-2 border-dashed border-[#24A5EE]/40 group-hover:border-[#24A5EE] bg-[#EFF6FF] dark:bg-[#181A20] rounded-[24px] flex flex-col items-center justify-center p-6 transition-all">
                                                    <div className="w-16 h-16 bg-white dark:bg-[#2A2E39] rounded-2xl shadow-sm flex items-center justify-center mb-4 text-[#24A5EE]">
                                                        <Upload size={28} />
                                                    </div>
                                                    <p className="text-sm font-bold text-[#162B6E] dark:text-white">{file ? file.name : "Drop Audio File"}</p>
                                                    <p className="text-[10px] text-[#64748B] mt-1 uppercase font-black">WAV or MP3 (Max 10MB)</p>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" disabled={uploading} className="w-full py-4 bg-[#24A5EE] hover:bg-[#1E88C8] text-white font-black rounded-2xl shadow-lg flex items-center justify-center gap-3 transition-all disabled:opacity-50">
                                            {uploading ? "Processing Frequencies..." : "Initialize Audio Lab"} <ArrowRight size={18} />
                                        </button>
                                    </form>
                                </motion.div>
                            ) : (
                                <motion.div
                                    key="sync"
                                    initial={{ opacity: 0, scale: 0.98 }}
                                    animate={{ opacity: 1, scale: 1 }}
                                    className="space-y-6"
                                >
                                    <div className="bg-[#162B6E] rounded-[40px] p-10 shadow-2xl relative overflow-hidden border border-white/5">
                                        <div className="absolute top-0 right-0 w-80 h-80 bg-[#24A5EE] opacity-10 blur-[120px] -mr-40 -mt-40" />

                                        <div className="relative z-10">
                                            <div className="flex justify-between items-start mb-12">
                                                <div className="flex items-center gap-4">
                                                    <div className="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center text-blue-300 backdrop-blur-md border border-white/10"><Music size={28} /></div>
                                                    <div>
                                                        <p className="text-white font-bold text-lg">{file?.name || "Greetings_Basic_01.wav"}</p>
                                                        <div className="flex items-center gap-2 mt-1">
                                                            <span className="px-2 py-0.5 bg-green-500/20 text-green-400 text-[9px] font-black rounded uppercase tracking-tighter">Studio Quality</span>
                                                            <span className="text-blue-300/60 text-[10px] font-medium tracking-wide">44.1kHz • 24-bit</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div className="text-right">
                                                    <p className="text-4xl font-mono font-black text-white tracking-tighter italic">00:04<span className="opacity-30 text-2xl">.82</span></p>
                                                </div>
                                            </div>

                                            {/* Advanced Animated Waveform */}
                                            <div className="h-32 w-full flex items-center justify-between gap-1.5 mb-12 px-2">
                                                {[40, 70, 45, 90, 65, 30, 85, 40, 70, 50, 95, 60, 40, 80, 50, 30, 70, 40, 90, 50, 60, 30].map((h, i) => (
                                                    <motion.div
                                                        key={i}
                                                        initial={{ height: "10%" }}
                                                        animate={{ height: isPlaying ? `${h}%` : "15%" }}
                                                        transition={{ repeat: Infinity, repeatType: "reverse", duration: 0.5, delay: i * 0.05 }}
                                                        className={`flex-1 rounded-full transition-colors duration-500 ${i < 12 ? 'bg-[#24A5EE]' : 'bg-white/10'}`}
                                                    />
                                                ))}
                                            </div>

                                            <div className="flex justify-center items-center gap-10">
                                                <button onClick={() => setIsPlaying(!isPlaying)} className="w-24 h-24 bg-white rounded-full flex items-center justify-center text-[#162B6E] shadow-2xl hover:scale-110 active:scale-95 transition-all">
                                                    {isPlaying ? <Pause size={38} fill="currentColor" /> : <Play size={38} fill="currentColor" className="ml-1" />}
                                                </button>
                                                <button className="bg-[#24A5EE] p-5 rounded-full text-white shadow-lg hover:rotate-12 hover:bg-white hover:text-[#24A5EE] transition-all"><Scissors size={26} /></button>
                                            </div>
                                        </div>
                                    </div>
                                    <button onClick={() => setView("upload")} className="group flex items-center gap-2 text-xs font-black text-[#64748B] hover:text-[#162B6E] uppercase tracking-widest transition-all">
                                        <X size={14} className="group-hover:rotate-90 transition-transform" /> Discard & Return to Uploader
                                    </button>
                                </motion.div>
                            )}
                        </AnimatePresence>
                    </div>

                    <aside className="lg:col-span-4 space-y-6">
                        <div className="bg-white dark:bg-[#1F222A] p-6 rounded-[28px] border border-[#E2E8F0] dark:border-[#2A2E39] shadow-premium">
                            <div className="flex items-center gap-4">
                                <ZabbotMascot mood={uploading ? "working" : (view === "sync" ? "celebrating" : "welcoming")} size={70} />
                                <div>
                                    <h4 className="font-black text-[#162B6E] dark:text-[#24A5EE] text-[10px] uppercase tracking-widest">System Assistant</h4>
                                    <p className="text-xs text-[#64748B] dark:text-[#B5B8C5] mt-1 font-medium leading-relaxed">
                                        {view === "upload" ? "Native Yorùbá requires high-frequency clarity. Ensure your WAV files are mono for best sync." : "Perfect! Map the 'High' and 'Low' tones by snipping the wave."}
                                    </p>
                                </div>
                            </div>
                        </div>

                        {view === "sync" && (
                            <motion.div initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} className="bg-white dark:bg-[#1F222A] rounded-[28px] border border-[#E2E8F0] dark:border-[#2A2E39] shadow-premium overflow-hidden">
                                <div className="p-5 bg-[#F8FAFC] dark:bg-[#181A20] border-b border-[#E2E8F0] dark:border-[#2A2E39]">
                                    <h4 className="text-[10px] font-black uppercase text-[#64748B] tracking-widest">Active Timestamps</h4>
                                </div>
                                <div className="p-5 space-y-3">
                                    {stamps.map((stamp, i) => (
                                        <div key={i} className="flex justify-between items-center p-4 bg-[#F8FAFC] dark:bg-[#0F1117] rounded-2xl border border-transparent hover:border-[#24A5EE]/30 group transition-all cursor-pointer">
                                            <div className="flex items-center gap-3">
                                                <div className="w-2 h-2 rounded-full bg-[#24A5EE]" />
                                                <span className="font-bold text-sm text-[#162B6E] dark:text-white">{stamp.word}</span>
                                            </div>
                                            <span className="font-mono text-[10px] font-black text-[#64748B] group-hover:text-[#24A5EE] transition-colors">{stamp.start} — {stamp.end}</span>
                                        </div>
                                    ))}
                                </div>
                            </motion.div>
                        )}
                    </aside>
                </div>
            </div>
        </div>
    );
}