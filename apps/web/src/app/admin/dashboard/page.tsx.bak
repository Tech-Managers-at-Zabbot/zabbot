"use client";

import React, { useState, useEffect } from "react";
import { 
  Plus, Trash2, Mic, ImageIcon, Globe, Loader2, 
  CheckCircle2, ArrowRight, Eye, Edit3, Music, X, Save, Database
} from "lucide-react";
import { createFullSpark, deleteSpark } from "../actions/spark-actions";

// --- UPDATED COMPONENT: DELETE BUTTON ---
function DeleteSparkButton({ id, title, onDeleteSuccess }: { id: string, title: string, onDeleteSuccess: () => void }) {
  const [isDeleting, setIsDeleting] = useState(false);

  const handleDelete = async () => {
    if (!confirm(`Permanently remove "${title}" from the Heritage Archive?`)) return;
    setIsDeleting(true);
    
    // FIX: Only passing 'id' to match the updated action signature
    const result = await deleteSpark(id); 
    
    if (result.success) {
      onDeleteSuccess();
    } else {
      alert("Delete failed: " + result.message);
    }
    setIsDeleting(false);
  };

  return (
    <button 
      onClick={handleDelete}
      disabled={isDeleting}
      className="p-3 bg-red-50 text-red-500 rounded-2xl hover:bg-red-500 hover:text-white transition-all disabled:opacity-50 border border-red-100"
    >
      {isDeleting ? <Loader2 size={16} className="animate-spin" /> : <Trash2 size={16} />}
    </button>
  );
}

export default function AdminDashboard() {
  const [isPending, setIsPending] = useState(false);
  const [isPreview, setIsPreview] = useState(false);
  const [showSuccess, setShowSuccess] = useState(false);
  const [lastSaved, setLastSaved] = useState<string | null>(null);
  
  // State for the form
  const [identity, setIdentity] = useState({
    title: "", 
    hero_image_url: "", 
    duration: "8 MINS", 
    xp: "25",
    summary: "", 
    honorific_rule: "", 
    proverb_yoruba: "", 
    proverb_english: ""
  });
  
  const [nodes, setNodes] = useState([{ yoruba: "", english: "", audio: "", grammar: "" }]);

  useEffect(() => {
    const draft = localStorage.getItem("zabbot_spark_draft");
    if (draft) {
      try {
        const { identity: id, nodes: nd } = JSON.parse(draft);
        setIdentity(id);
        setNodes(nd);
      } catch (e) {
        console.error("Failed to parse draft", e);
      }
    }
  }, []);

  const handlePublish = async () => {
    setIsPending(true);
    const formData = new FormData();
    
    // Append identity fields
    Object.entries(identity).forEach(([key, value]) => formData.append(key, value));
    // Append nodes as JSON string
    formData.append("nodes_data", JSON.stringify(nodes));
    
    try {
      // In Next.js Server Actions, the first argument for useActionState is 'prevState'
      // Since we are calling it directly here, we pass null as the first arg.
      const result = await createFullSpark(null, formData);
      
      if (result.success) {
        setShowSuccess(true);
        localStorage.removeItem("zabbot_spark_draft");
        setIdentity({ title: "", hero_image_url: "", duration: "8 MINS", xp: "25", summary: "", honorific_rule: "", proverb_yoruba: "", proverb_english: "" });
        setNodes([{ yoruba: "", english: "", audio: "", grammar: "" }]);
        setTimeout(() => setShowSuccess(false), 5000);
      }
    } catch (error) {
       console.error("Publishing error:", error);
    } finally {
      setIsPending(false);
    }
  };

  // ... (Rest of your UI components: AdminInput, AdminTextArea, PreviewScreen stay as they are)

  if (isPreview) return <PreviewScreen identity={identity} nodes={nodes} onEdit={() => setIsPreview(false)} onPublish={handlePublish} isPending={isPending} />;

  return (
    <main className="relative flex-1 min-h-screen bg-[#F8FAFC] p-8 lg:p-12 overflow-y-auto">
      {/* UI logic remains the same */}
      {showSuccess && (
        <div className="fixed top-10 right-10 z-[100] bg-[#16A34A] text-white px-8 py-4 rounded-3xl shadow-2xl flex items-center gap-4 animate-in slide-in-from-right font-black uppercase text-xs tracking-widest">
          <CheckCircle2 size={20} /> Spark Committed to Neon
        </div>
      )}
      
      {/* ... Render the rest of your form sections ... */}
      <header className="mb-10 flex justify-between items-end border-b border-slate-200 pb-6">
        <div>
          <h1 className="text-4xl font-black text-[#162B6E] tracking-tight">Sparks Studio</h1>
          <p className="text-[#24A5EE] font-bold uppercase text-[11px] tracking-[0.2em] mt-2">
            ZABBOT ENGINE • HERITAGE MODE V1.2
          </p>
        </div>
        <div className="flex gap-4">
            <button onClick={() => setIsPreview(true)} className="flex items-center gap-2 px-8 py-4 bg-white border-2 border-slate-100 text-[#162B6E] rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-sm hover:border-[#24A5EE] transition-all">
                <Eye size={16} /> Preview
            </button>
        </div>
      </header>

      <div className="grid grid-cols-1 xl:grid-cols-3 gap-10">
        <div className="xl:col-span-2 space-y-10">
          <section className="bg-white p-10 rounded-[48px] shadow-sm border border-slate-100 space-y-8">
              <div className="flex items-center gap-3"><ImageIcon className="text-blue-400" /> <h3 className="text-xl font-black text-[#162B6E] uppercase">Base Identity</h3></div>
              <AdminInput label="Lesson Title" value={identity.title} onChange={(e:any) => setIdentity({...identity, title: e.target.value})} />
              <AdminTextArea label="Summary" value={identity.summary} onChange={(e:any) => setIdentity({...identity, summary: e.target.value})} />
          </section>
          
          <section className="bg-white p-10 rounded-[48px] shadow-sm border border-red-100">
             <div className="flex items-center gap-3 mb-6">
               <Database className="text-red-400" size={20} />
               <h3 className="text-xl font-black text-[#162B6E] uppercase tracking-tight">System Controls</h3>
             </div>
             <div className="p-6 bg-red-50/50 rounded-3xl border border-red-50 flex items-center justify-between">
                <div>
                  <p className="text-xs font-black text-red-900 uppercase">Reset Local Buffer</p>
                </div>
                <button onClick={() => {localStorage.removeItem("zabbot_spark_draft"); window.location.reload();}} className="px-6 py-3 bg-white text-red-500 rounded-xl font-black text-[10px] uppercase border border-red-100 shadow-sm">Reset Canvas</button>
             </div>
          </section>
        </div>

        <aside>
          <div className="bg-[#162B6E] p-10 rounded-[56px] text-white space-y-8 sticky top-8 shadow-2xl border border-white/5">
             <div className="flex items-center gap-3"><Globe className="text-[#24A5EE]" size={20} /> <h3 className="text-xl font-black uppercase">Cultural Meta</h3></div>
             <AdminInput dark label="Yorùbá Proverb" value={identity.proverb_yoruba} onChange={(e:any) => setIdentity({...identity, proverb_yoruba: e.target.value})} />
             <AdminInput dark label="Proverb Translation" value={identity.proverb_english} onChange={(e:any) => setIdentity({...identity, proverb_english: e.target.value})} />
             
             <button 
               onClick={handlePublish}
               disabled={isPending || !identity.title}
               className="w-full bg-[#24A5EE] py-8 rounded-[32px] font-black text-xs uppercase tracking-[0.3em] shadow-xl hover:bg-white hover:text-[#162B6E] transition-all flex items-center justify-center gap-3 disabled:opacity-50"
             >
               {isPending ? <Loader2 className="animate-spin" /> : <>Publish Full Spark <ArrowRight size={18} /></>}
             </button>
          </div>
        </aside>
      </div>
    </main>
  );
}

// SHARED COMPONENTS (Consider moving these to StudioUI.tsx)
function AdminInput({ label, value, onChange, dark = false, type = "text", placeholder }: any) {
  return (
    <div className="flex flex-col gap-3">
      <label className={`text-[10px] font-black uppercase tracking-[0.2em] ${dark ? "text-white/40" : "text-slate-400"}`}>{label}</label>
      <input 
        type={type} value={value} onChange={onChange} placeholder={placeholder}
        className={`w-full p-5 rounded-[24px] text-sm font-bold border outline-none transition-all ${
          dark ? "bg-white/5 border-white/10 text-white" : "bg-slate-50 border-slate-100 text-[#162B6E]"
        }`} 
      />
    </div>
  );
}

function AdminTextArea({ label, value, onChange, dark = false, placeholder }: any) {
  return (
    <div className="flex flex-col gap-3">
      <label className={`text-[10px] font-black uppercase tracking-[0.2em] ${dark ? "text-white/40" : "text-slate-400"}`}>{label}</label>
      <textarea 
        rows={4} value={value} onChange={onChange} placeholder={placeholder}
        className={`w-full p-6 rounded-[32px] text-sm font-bold border outline-none transition-all resize-none ${
          dark ? "bg-white/5 border-white/10 text-white" : "bg-slate-50 border-slate-100 text-[#162B6E]"
        }`} 
      />
    </div>
  );
}

function PreviewScreen({ identity, nodes, onEdit, onPublish, isPending }: any) {
  return (
    <div className="min-h-screen bg-[#F8FAFC] p-12">
      <button onClick={onEdit} className="text-[#24A5EE] font-black uppercase text-xs mb-8 flex items-center gap-2">
        <Edit3 size={16} /> Edit Spark
      </button>
      <h1 className="text-5xl font-black text-[#162B6E] mb-12">{identity.title || "Untitled"}</h1>
      {/* ... rest of your preview UI */}
      <button onClick={onPublish} disabled={isPending} className="bg-[#16A34A] text-white px-12 py-6 rounded-3xl font-black uppercase">
        {isPending ? "Committing..." : "Confirm Publish"}
      </button>
    </div>
  );
}