import { db } from "@/lib/db"; // Use Prisma instead of Neon direct
import { History, Zap, Edit3, Trash2, Calendar, Eye, EyeOff } from 'lucide-react';
import Link from 'next/link';
import { deleteSpark } from '../actions/spark-actions';

export const dynamic = 'force-dynamic';
export const revalidate = 0;

export default async function HeritageArchive() {
    // 1. Fetch data using Prisma for type safety and consistency
    const sparks = await db.spark.findMany({
        orderBy: {
            createdAt: 'desc'
        }
    });
    
    // 2. Calculate stats using Prisma
    const total = sparks.length;
    const live = sparks.filter(s => s.isPublished).length;
    const drafts = total - live;

    return (
        <div className="space-y-10 p-8 lg:p-12 max-w-7xl mx-auto min-h-screen">
            {/* HEADER */}
            <div className="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                <div>
                    <div className="flex items-center gap-2 text-[#24A5EE] mb-2">
                        <History size={16} />
                        <span className="text-[10px] font-black uppercase tracking-[0.3em]">Master Repository</span>
                    </div>
                    <h1 className="text-5xl font-black text-[#162B6E] tracking-tighter italic">Heritage Archive</h1>
                </div>
                
                <Link href="/admin/sparks" className="px-8 py-4 bg-[#162B6E] text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-[#24A5EE] transition-all flex items-center gap-2 shadow-xl">
                    <Zap size={14} fill="currentColor" /> Create New Spark
                </Link>
            </div>

            {/* STATS */}
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div className="bg-white p-8 rounded-[40px] border border-slate-100 shadow-sm">
                    <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Inventory Overview</p>
                    <div className="flex items-baseline gap-4">
                        <h3 className="text-4xl font-black text-[#162B6E]">{live} <span className="text-xs text-green-500 uppercase tracking-widest">Live</span></h3>
                        <h3 className="text-4xl font-black text-slate-300">{drafts} <span className="text-xs text-slate-400 uppercase tracking-widest">Drafts</span></h3>
                    </div>
                </div>
            </div>

            {/* TABLE */}
            <div className="bg-white rounded-[48px] overflow-hidden border border-slate-100 shadow-sm">
                <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse">
                        <thead>
                            <tr className="bg-slate-50/50 border-b border-slate-100">
                                <th className="px-8 py-6 text-[10px] font-black text-slate-400 uppercase">Status</th>
                                <th className="px-8 py-6 text-[10px] font-black text-slate-400 uppercase">Spark Identity</th>
                                <th className="px-8 py-6 text-[10px] font-black text-slate-400 uppercase text-center">Metrics</th>
                                <th className="px-8 py-6 text-[10px] font-black text-slate-400 uppercase text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-slate-50">
                            {sparks.map((spark) => (
                                <tr key={spark.id} className="hover:bg-slate-50/50 transition-colors group">
                                    <td className="px-8 py-6">
                                        {spark.isPublished ? (
                                            <span className="flex items-center gap-1.5 text-green-600 bg-green-50 px-3 py-1 rounded-full text-[9px] font-black uppercase border border-green-100 w-fit">
                                                <Eye size={10} /> Live
                                            </span>
                                        ) : (
                                            <span className="flex items-center gap-1.5 text-slate-400 bg-slate-50 px-3 py-1 rounded-full text-[9px] font-black uppercase border border-slate-100 w-fit">
                                                <EyeOff size={10} /> Draft
                                            </span>
                                        )}
                                    </td>
                                    <td className="px-8 py-6">
                                        <div className="flex items-center gap-4">
                                            <div className="w-14 h-14 bg-slate-100 rounded-2xl overflow-hidden shrink-0 border border-slate-200">
                                                {spark.imageThumbnail && (
                                                    <img src={spark.imageThumbnail} alt="" className="w-full h-full object-cover" />
                                                )}
                                            </div>
                                            <div>
                                                <p className="font-black text-[#162B6E] text-sm group-hover:text-[#24A5EE] transition-colors">{spark.title}</p>
                                                <div className="flex items-center gap-2 mt-1">
                                                    <Calendar size={12} className="text-slate-300" />
                                                    <p className="text-[10px] text-slate-400 font-bold uppercase tracking-tight">
                                                        {new Date(spark.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td className="px-8 py-6 text-center">
                                        <div className="flex justify-center gap-2">
                                            <span className="px-3 py-1 bg-blue-50 text-[#24A5EE] text-[9px] font-black rounded-full border border-blue-100">{spark.timeEstimate}m</span>
                                            <span className="px-3 py-1 bg-yellow-50 text-yellow-600 text-[9px] font-black rounded-full border border-yellow-100">{spark.xpReward} XP</span>
                                        </div>
                                    </td>
                                    <td className="px-8 py-6">
                                        <div className="flex items-center justify-end gap-3">
                                            <Link href={`/admin/sparks/edit/${spark.id}`} className="p-3 text-slate-400 hover:text-[#162B6E] hover:bg-white rounded-xl transition-all shadow-sm border border-transparent hover:border-slate-100">
                                                <Edit3 size={18} />
                                            </Link>
                                            
                                            <form action={async () => {
                                                'use server';
                                                // FIXED: Passing only ID to match the new Prisma action
                                                await deleteSpark(spark.id);
                                            }}>
                                                <button type="submit" className="p-3 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                                                    <Trash2 size={18} />
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    );
}